generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  ADMIN
  ENGINEER
  SALES
  CLIENT
}

enum ProjectStatus {
  LEAD
  DIAGNOSIS
  PROPOSAL
  IMPLEMENTATION
  MONITORING
  CLOSED
}

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
  VOID
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAUSED
  CANCELED
}

model User {
  id        String   @id @default(cuid())
  name      String?
  email     String   @unique
  role      UserRole @default(CLIENT)
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Company {
  id            String         @id @default(cuid())
  name          String
  taxId         String?        @unique
  email         String?
  phone         String?
  country       String         @default("CL")
  sites         Site[]
  users         User[]
  projects      Project[]
  invoices      Invoice[]
  subscriptions Subscription[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model Site {
  id           String           @id @default(cuid())
  companyId    String
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name         String
  address      String?
  businessType String?
  tariffCode   String?
  region       String?
  bills        ElectricBill[]
  analyses     EnergyAnalysis[]
  measurements Measurement[]
  projects     Project[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([companyId])
}

model ElectricBill {
  id                 String           @id @default(cuid())
  siteId             String
  site               Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  distributor        String?
  customerNumber     String?
  billingMonth       String?
  totalAmountClp     Int?
  energyKwh          Float?
  energyCostClp      Int?
  powerChargeClp     Int?
  reactivePenaltyClp Int?
  otherChargesClp    Int?
  contractedPowerKw  Float?
  peakDemandKw       Float?
  fileUrl            String?
  rawOcr             Json?
  normalizedCharges  Json?
  analyses           EnergyAnalysis[]
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([siteId])
  @@index([billingMonth])
}

model EnergyAnalysis {
  id                      String           @id @default(cuid())
  siteId                  String
  site                    Site             @relation(fields: [siteId], references: [id], onDelete: Cascade)
  billId                  String?
  bill                    ElectricBill?    @relation(fields: [billId], references: [id], onDelete: SetNull)
  totalAmountClp          Int?
  estimatedSavingsClp     Int?
  estimatedSavingsPercent Float?
  annualSavingsClp        Int?
  opportunityScore        Int              @default(0)
  powerIssue              Boolean          @default(false)
  reactiveIssue           Boolean          @default(false)
  consumptionIssue        Boolean          @default(false)
  qualityIssue            Boolean          @default(false)
  technicalSummary        String?
  commercialSummary       String?
  auditTrail              Json?
  recommendations         Recommendation[]
  proposals               Proposal[]
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@index([siteId])
  @@index([billId])
}

model Recommendation {
  id          String         @id @default(cuid())
  analysisId  String
  analysis    EnergyAnalysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)
  category    String
  priority    Int            @default(2)
  title       String
  description String
  impactClp   Int?
  status      String         @default("OPEN")
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([analysisId])
}

model Project {
  id          String        @id @default(cuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  siteId      String?
  site        Site?         @relation(fields: [siteId], references: [id], onDelete: SetNull)
  name        String
  status      ProjectStatus @default(LEAD)
  targetClp   Int?
  startDate   DateTime?
  endDate     DateTime?
  proposals   Proposal[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([companyId])
  @@index([siteId])
}

model Proposal {
  id                 String         @id @default(cuid())
  projectId          String?
  project            Project?       @relation(fields: [projectId], references: [id], onDelete: SetNull)
  analysisId         String?
  analysis           EnergyAnalysis? @relation(fields: [analysisId], references: [id], onDelete: SetNull)
  status             ProposalStatus @default(DRAFT)
  title              String
  implementationClp  Int?
  upfrontPercent     Float          @default(0.35)
  sharedSavingsRate  Float          @default(0.3)
  monthlyFeeClp      Int?
  payload            Json?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([projectId])
  @@index([analysisId])
}

model Measurement {
  id             String   @id @default(cuid())
  siteId         String
  site           Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  measuredAt     DateTime
  energyKwh      Float?
  maxDemandKw    Float?
  powerFactor    Float?
  voltageQuality Json?
  source         String   @default("MANUAL")
  createdAt      DateTime @default(now())

  @@index([siteId])
  @@index([measuredAt])
}

model Invoice {
  id          String        @id @default(cuid())
  companyId   String
  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status      InvoiceStatus @default(DRAFT)
  amountClp   Int
  issuedAt    DateTime?
  dueAt       DateTime?
  paidAt      DateTime?
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([companyId])
}

model Subscription {
  id          String             @id @default(cuid())
  companyId   String
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  status      SubscriptionStatus @default(TRIAL)
  plan        String             @default("monitoring")
  monthlyClp  Int                @default(49000)
  startedAt   DateTime           @default(now())
  endedAt     DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([companyId])
}
